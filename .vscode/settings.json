{
  "files.exclude": {
    ".npmrc": true,
    "package-lock.json": true,
    "stackprof.dump": true,
    "node_modules": true,
    "public": true,
    ".cache": true,
    "**/.gitkeep": true,
    "**/.gitattributes": true,
    "**/coverage": true,
    "**/Gemfile.lock": true,
    "**/.rspec": true,
    "**/.simplecov": true
  },
  "[typescript]": {
    "editor.indentSize": "tabSize",
    "editor.tabSize": 2,
  },
  "[typescriptreact]": {
    "editor.tabSize": 2,
  },
  "rubyLsp.rubyVersionManager": {
    "identifier": "rbenv"
  },
  "rubyLsp.formatter": "none",
  "rubyLsp.pullDiagnosticsOn": "save"
}
